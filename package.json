{
    "name": "surprisehub",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev -p 3000",
        "build": "next build",
        "start": "next start",
        "test": "vitest",
        "test:coverage": "vitest --coverage --environment jsdom",
        "test:unit": "vitest --environment jsdom app/**/*.test.jsx",
        "test:api": "vitest --environment node app/api/**/*.test.js",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:all": "npm run test:coverage && npm run test:e2e",
        "ci": "npm run test:coverage && npm ci && npm run build && npm run test:e2e"
    },
    "dependencies": {
        "@playwright/test": "1.57.0",
        "@upstash/ratelimit": "^2.0.8",
        "@upstash/redis": "^1.37.0",
        "@vercel/speed-insights": "^1.3.1",
        "@vitejs/plugin-react": "^4.0.0",
        "dotenv": "^17.4.2",
        "html2canvas": "^1.4.1",
        "jspdf": "^4.2.1",
        "next": "^14.2.35",
        "openai": "^6.34.0",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "resend": "^6.11.0",
        "vite": "^6.4.2",
        "vitest": "^3.2.4",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.0.2",
        "@testing-library/react": "^14.0.0",
        "@vitest/coverage-v8": "^3.2.4",
        "jsdom": "^26.1.0"
    }
}
