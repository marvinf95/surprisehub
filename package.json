{
    "name": "surprisehub",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev -p 3000",
        "build": "next build",
        "start": "next start",
        "test": "vitest",
        "test:coverage": "vitest --coverage --environment jsdom",
        "test:unit": "vitest --environment jsdom app/**/*.test.jsx",
        "test:api": "vitest --environment node app/api/**/*.test.js",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:all": "npm run test:coverage && npm run test:e2e",
        "ci": "npm run test:coverage && npm ci && npm run build && npm run test:e2e"
    },
    "dependencies": {
        "@playwright/test": "1.59.1",
        "@upstash/ratelimit": "^2.0.8",
        "@upstash/redis": "^1.37.0",
        "@vercel/speed-insights": "^2.0.0",
        "@vitejs/plugin-react": "^6.0.1",
        "dompurify": "^3.4.0",
        "dotenv": "^17.4.2",
        "html2canvas": "^1.4.1",
        "jspdf": "^4.2.1",
        "next": "^16.2.3",
        "openai": "^6.34.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "resend": "^6.12.0",
        "vite": "^8.0.8",
        "vitest": "^4.1.4",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.0.2",
        "@testing-library/react": "^16.3.2",
        "@vitest/coverage-v8": "^4.1.4",
        "jsdom": "^29.0.2"
    }
}
